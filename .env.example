# =============================================================================
# Pick ONE of the three provider paths below. The tray menu also lets you
# switch at runtime, but you need at least one provider configured.
# =============================================================================

# ---- 1. H Company hosted API (recommended — no GPU infra) -------------------
# Sign up at https://hub.hcompany.ai (Portal-H), generate an API key.
# Pay per token; full-quality model; native reasoning + structured outputs.
HAI_API_KEY=
HCOMPANY_MODEL=holo3-35b-a3b

# ---- 2. Modal — self-hosted Holo3 GGUF on L4 GPU ----------------------------
# Set after `modal deploy modal_app.py`. Cheapest 24GB GPU; pay per second
# while a request is in flight; auto-scales to zero after 10 min idle.
MODAL_BASE_URL=https://YOUR-USERNAME--holo3-agent
MODAL_BEARER_TOKEN=

# ---- 3. Local provider (Ollama) — fully offline -----------------------------
# Run `bash scripts/setup-local.sh` once to import the GGUF into Ollama.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=holo3

# Convex — set by `npx convex dev` automatically into .env.local
VITE_CONVEX_URL=https://YOUR-DEPLOYMENT.convex.cloud
