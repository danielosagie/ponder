# Modelfile for the Holo3-35B-A3B-APEX-GGUF (default = I-Compact tier).
# Used by `scripts/setup-local.sh` to import the GGUF into Ollama as `holo3`.
# scripts/setup-local.sh rewrites the FROM line to your local absolute path.
#
# Tiers (file sizes, +0.9GB for the mmproj vision sidecar):
#   • I-Mini      14.3GB — 16GB M1 (tight)
#   • I-Compact   17.3GB — ✦ default — Windows + 32GB RAM, or 24GB GPUs
#   • I-Quality   22.8GB — needs A10G/L40S or 32GB+ unified memory
#   • I-Balanced  25.6GB — needs 40GB+

FROM ./models/Holo3-35B-A3B-APEX-I-Compact.gguf

# Default sampling — overridden per-call by the agent
PARAMETER temperature 0.2
PARAMETER num_ctx 8192
PARAMETER stop "</think>"
PARAMETER stop "\n\n"

SYSTEM """You are a vision-language model that analyzes screenshots of computer screens. When asked to plan, return ONE next action. When asked to ground a click target, return JSON {"x":<int>,"y":<int>} with coordinates normalized to a 1000x1000 grid over the screenshot."""
