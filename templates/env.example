# =============================================================================
# Ponder configuration
# =============================================================================
# This file is committed to source control. Real values live in `.env`,
# which is gitignored. The `# managed by ponder` block in `.env` is rewritten
# by `npx ponder set-provider` — anything outside it is left alone.

# Convex deployment URL (auto-populated by `npx convex dev`)
VITE_CONVEX_URL=https://YOUR-DEPLOYMENT.convex.cloud

# Active provider — one of: hcompany | remote | local
PONDER_PROVIDER=hcompany

# ---- Hosted: H Company API ----------------------------------------------
# Sign up at https://hub.hcompany.ai (Portal-H), generate an API key.
HAI_API_KEY=
HCOMPANY_MODEL=holo3-35b-a3b

# ---- Self-hosted on Modal ------------------------------------------------
# Set after `npx ponder set-provider modal` (or `modal deploy modal_app.py`).
MODAL_BASE_URL=
MODAL_BEARER_TOKEN=

# ---- Local Ollama --------------------------------------------------------
# Run `npx ponder set-provider local` (or `bash scripts/setup-local.sh`).
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=holo3
